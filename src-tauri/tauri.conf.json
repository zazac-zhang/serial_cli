{
  "$schema": "https://schema.tauri.app/config/2.0.json",
  "productName": "Serial CLI",
  "version": "0.1.0",
  "identifier": "com.serial-cli.gui",
  "build": {
    "beforeDevCommand": "cd src-ui && npm run dev",
    "beforeBuildCommand": "cd src-ui && npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "/Users/pony/codehub/rust/serial_cli/src-ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Serial CLI",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 1000,
        "minHeight": 600,
        "visible": true,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true,
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
